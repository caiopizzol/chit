{
	"name": "chit-workspace",
	"version": "0.0.0",
	"private": true,
	"description": "chit — a thin runtime for multi-agent workflows. Monorepo root.",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"test": "bun --filter '*' test",
		"typecheck": "bun --filter '*' typecheck",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check:staged:fix": "biome check --write --staged --no-errors-on-unmatched",
		"prepare": "lefthook install",
		"check:browser": "bun --filter '@chit/core' check:browser",
		"cli": "bun --cwd apps/cli src/cli/run.ts",
		"site:dev": "bun --filter @chit/site dev",
		"site:build": "bun --filter @chit/site build",
		"site:preview": "bun --filter @chit/site preview",
		"site:typecheck": "bun --filter @chit/site typecheck",
		"site:deploy": "bun --filter @chit/site deploy",
		"docs:dev": "bun run site:dev",
		"docs:build": "bun run site:build",
		"docs:preview": "bun run site:preview",
		"docs:typecheck": "bun run site:typecheck",
		"docs:deploy": "bun run site:deploy",
		"studio:build": "bun --filter @chit/studio build:client",
		"studio:preview": "bun run studio:build && bun --cwd apps/cli src/cli/run.ts studio examples/consult.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.14",
		"lefthook": "^2.1.9",
		"typescript": "^6.0.3"
	}
}
