{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://chit.dev/schemas/chit.schema.json",
	"title": "Chit config",
	"description": "Authoring schema for a Chit config file. Semantic rules are still enforced by the Chit parser and resolver.",
	"type": "object",
	"additionalProperties": false,
	"required": ["routines"],
	"properties": {
		"$schema": { "type": "string" },
		"profiles": {
			"type": "object",
			"description": "Preferred name for local adapter/model bindings.",
			"additionalProperties": { "$ref": "#/$defs/profile" }
		},
		"agents": {
			"type": "object",
			"description": "Compatibility alias for profiles.",
			"additionalProperties": { "$ref": "#/$defs/profile" }
		},
		"routines": {
			"type": "object",
			"additionalProperties": { "$ref": "#/$defs/routineEntry" }
		}
	},
	"$defs": {
		"profile": {
			"oneOf": [
				{
					"type": "string",
					"description": "Adapter or adapter:model shorthand, for example codex:gpt-5.5 or gemini."
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["adapter"],
					"properties": {
						"adapter": { "type": "string", "minLength": 1 },
						"model": { "type": "string" }
					}
				}
			]
		},
		"routineEntry": {
			"oneOf": [
				{ "type": "string", "description": "Path to a routine file." },
				{ "$ref": "#/$defs/fileRoutine" },
				{ "$ref": "#/$defs/inlineRoutine" }
			]
		},
		"fileRoutine": {
			"type": "object",
			"additionalProperties": false,
			"oneOf": [
				{ "required": ["file"] },
				{ "required": ["manifestPath"] }
			],
			"properties": {
				"file": { "type": "string", "minLength": 1 },
				"manifestPath": { "type": "string", "minLength": 1 },
				"description": { "type": "string" },
				"defaults": { "$ref": "#/$defs/defaults" }
			}
		},
		"inlineRoutine": {
			"type": "object",
			"additionalProperties": false,
			"required": ["steps"],
			"properties": {
				"id": { "type": "string" },
				"description": { "type": "string" },
				"input": { "type": "string", "minLength": 1 },
				"inputs": {
					"oneOf": [
						{
							"type": "array",
							"items": { "type": "string", "minLength": 1 }
						},
						{
							"type": "object",
							"additionalProperties": { "$ref": "#/$defs/inputSpec" }
						}
					]
				},
				"agents": {
					"type": "object",
					"additionalProperties": { "$ref": "#/$defs/participant" }
				},
				"participants": {
					"type": "object",
					"additionalProperties": { "$ref": "#/$defs/participant" }
				},
				"steps": {
					"type": "array",
					"minItems": 1,
					"items": { "$ref": "#/$defs/step" }
				},
				"repeat": { "$ref": "#/$defs/repeat" },
				"output": { "type": "string" },
				"limits": { "$ref": "#/$defs/limits" },
				"defaults": { "$ref": "#/$defs/defaults" }
			}
		},
		"inputSpec": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"type": { "const": "string" },
				"required": { "type": "boolean" },
				"description": { "type": "string" }
			}
		},
		"participant": {
			"type": "object",
			"additionalProperties": false,
			"required": ["instructions", "filesystem"],
			"properties": {
				"profile": { "type": "string", "minLength": 1 },
				"agent": { "type": "string", "minLength": 1 },
				"instructions": { "type": "string", "minLength": 1 },
				"filesystem": {
					"enum": ["none", "read-only", "read-write"]
				}
			}
		},
		"step": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id"],
			"properties": {
				"id": { "type": "string", "minLength": 1 },
				"call": { "type": "string", "minLength": 1 },
				"prompt": { "type": "string", "minLength": 1 },
				"format": { "type": "string", "minLength": 1 },
				"check": { "$ref": "#/$defs/check" },
				"routine": { "type": "string", "minLength": 1 },
				"inputs": {
					"type": "object",
					"additionalProperties": { "type": "string" }
				},
				"ask": { "type": "string", "minLength": 1 }
			}
		},
		"check": {
			"oneOf": [
				{ "type": "string", "minLength": 1 },
				{
					"type": "array",
					"minItems": 1,
					"items": {
						"oneOf": [
							{ "type": "string", "minLength": 1 },
							{ "$ref": "#/$defs/checkCommand" }
						]
					}
				}
			]
		},
		"checkCommand": {
			"type": "object",
			"additionalProperties": false,
			"required": ["command"],
			"properties": {
				"command": { "type": "string", "minLength": 1 },
				"args": {
					"type": "array",
					"items": { "type": "string" }
				}
			}
		},
		"repeat": {
			"type": "object",
			"additionalProperties": false,
			"required": ["until"],
			"properties": {
				"until": { "$ref": "#/$defs/repeatUntil" },
				"maxIterations": { "type": "integer", "minimum": 1 }
			}
		},
		"repeatUntil": {
			"oneOf": [
				{ "const": "checks-pass" },
				{ "$ref": "#/$defs/stepEquals" },
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["all"],
					"properties": {
						"all": {
							"type": "array",
							"minItems": 1,
							"items": {
								"oneOf": [
									{ "const": "checks-pass" },
									{ "$ref": "#/$defs/stepEquals" }
								]
							}
						}
					}
				}
			]
		},
		"stepEquals": {
			"type": "object",
			"additionalProperties": false,
			"required": ["step", "equals"],
			"properties": {
				"step": { "type": "string", "minLength": 1 },
				"equals": { "type": "string" }
			}
		},
		"limits": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"callTimeoutMinutes": { "$ref": "#/$defs/minutes" },
				"runTimeoutMinutes": { "$ref": "#/$defs/minutes" }
			}
		},
		"defaults": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"maxIterations": { "type": "integer", "minimum": 1 }
			}
		},
		"minutes": {
			"oneOf": [
				{ "type": "number", "exclusiveMinimum": 0 },
				{ "const": "none" }
			]
		}
	}
}
