{
	"schema": 1,
	"id": "consult",
	"description": "Ask two advisors in parallel and format both answers.",
	"inputs": { "question": { "type": "string" } },
	"requires": { "can_show_markdown": true },
	"participants": {
		"codex": { "agent": "codex", "role": "Second opinion advisor.", "session": "per_scope" },
		"claude": { "agent": "claude", "role": "Second opinion advisor.", "session": "per_scope" }
	},
	"steps": {
		"ask_codex": { "call": "codex", "prompt": "{{ inputs.question }}" },
		"ask_claude": { "call": "claude", "prompt": "{{ inputs.question }}" },
		"out": {
			"format": "## codex\n\n{{ steps.ask_codex.output }}\n\n## claude\n\n{{ steps.ask_claude.output }}"
		}
	},
	"output": "out"
}
