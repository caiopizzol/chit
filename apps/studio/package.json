{
	"name": "@chit-run/studio",
	"version": "0.0.0",
	"private": true,
	"description": "chit Studio. Local visual control tower for live Chit activity, launched by `chit studio`. Bun+Hono server (src/server/) plus a React client (src/client/) that reads GET /api/live.",
	"type": "module",
	"exports": {
		"./server": "./src/server/index.ts",
		"./config": "./src/server/config.ts"
	},
	"scripts": {
		"build:client": "bun scripts/build-client.ts",
		"test": "bun test src",
		"typecheck": "tsc --noEmit",
		"check": "biome check ."
	},
	"dependencies": {
		"@chit-run/core": "workspace:*",
		"hono": "^4.6.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3"
	}
}
