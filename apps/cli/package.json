{
	"name": "chit-cli",
	"version": "0.0.0",
	"private": true,
	"description": "chit CLI. A thin runtime for multi-agent workflows.",
	"type": "module",
	"bin": {
		"chit": "src/cli/run.ts"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"start": "bun src/cli/run.ts"
	},
	"dependencies": {
		"@chit/core": "workspace:*"
	}
}
