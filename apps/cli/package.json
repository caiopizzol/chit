{
	"name": "@chit-run/cli",
	"version": "0.0.0",
	"description": "Versioned, cross-vendor agent routines with an audit trail. Stop being the glue between your agents.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://chit.run",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/caiopizzol/chit.git",
		"directory": "apps/cli"
	},
	"keywords": [
		"chit",
		"agents",
		"multi-agent",
		"workflow",
		"cli",
		"mcp",
		"claude",
		"codex"
	],
	"bin": {
		"chit": "dist/chit.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run build.ts",
		"prepack": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"start": "bun src/cli/run.ts"
	},
	"devDependencies": {
		"@chit-run/core": "workspace:*",
		"@chit-run/studio": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.18.0",
		"zod": "^4.4.3"
	}
}
