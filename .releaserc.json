{
	"branches": ["main"],
	"tagFormat": "v${version}",
	"plugins": [
		"@semantic-release/commit-analyzer",
		"@semantic-release/release-notes-generator",
		[
			"@semantic-release/exec",
			{
				"verifyConditionsCmd": "bun pm whoami",
				"prepareCmd": "cd apps/cli && npm pkg set version=${nextRelease.version} && bun run build",
				"publishCmd": "cd apps/cli && bun publish --access public"
			}
		],
		"@semantic-release/github"
	]
}
