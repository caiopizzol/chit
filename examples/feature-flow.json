{
	"id": "feature-flow",
	"description": "Grill an idea, plan it, then implement-and-verify it -- one composed routine.",
	"inputs": {
		"idea": { "type": "string", "required": true, "description": "the feature idea to take from question to code" }
	},
	"steps": [
		{ "id": "grill", "routine": "feature-griller", "inputs": { "idea": "{{ inputs.idea }}" } },
		{ "id": "plan", "routine": "planning", "inputs": { "goal": "{{ steps.grill.output }}" } },
		{ "id": "impl", "routine": "implementation-review", "inputs": { "task": "{{ steps.plan.output }}" } }
	]
}
