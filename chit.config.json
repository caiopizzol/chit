{
	"routines": {
		"feature-griller": {
			"manifestPath": "examples/feature-griller.json",
			"description": "Question a feature idea before implementation."
		},
		"planning": {
			"manifestPath": "examples/planning.json",
			"description": "Turn a goal into a small, ordered implementation plan."
		},
		"implementation-review": {
			"manifestPath": "examples/implementation-review.json",
			"description": "Implement, review, and verify a code slice.",
			"defaults": { "maxIterations": 3 }
		},
		"sandbox-smoke": {
			"manifestPath": "examples/sandbox-smoke.json",
			"description": "Tiny real converge smoke (creates smoke.txt in a sandbox)."
		},
		"forced-revise": {
			"manifestPath": "examples/forced-revise.json",
			"description": "Forces a real multi-iteration recovery (learn-from-failing-check)."
		},
		"feature-flow": {
			"manifestPath": "examples/feature-flow.json",
			"description": "Composed: grill -> plan -> implementation-review."
		}
	},
	"agents": {
		"claude": { "adapter": "claude", "model": "default" },
		"builder": { "adapter": "claude", "model": "default" },
		"critic": { "adapter": "claude", "model": "default" }
	}
}
