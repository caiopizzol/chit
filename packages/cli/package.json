{
	"name": "@chit-run/cli",
	"version": "0.0.0",
	"private": false,
	"type": "module",
	"description": "A thin local runtime for declared multi-model workflows.",
	"license": "MIT",
	"homepage": "https://chit.run",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/caiopizzol/chit.git",
		"directory": "packages/cli"
	},
	"bin": {
		"chit": "./src/index.ts"
	},
	"files": [
		"src",
		"schemas",
		"examples",
		"!src/**/*.test.ts"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"chit": "bun --no-env-file src/index.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"ajv": "^8.20.0",
		"typescript": "^5.6.0"
	}
}
