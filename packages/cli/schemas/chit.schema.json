{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://chit.run/schemas/chit.schema.json",
	"title": "Chit config",
	"description": "Authoring schema for a Chit config file. Semantic rules are still enforced by the Chit parser and resolver.",
	"type": "object",
	"additionalProperties": false,
	"required": ["routines"],
	"properties": {
		"$schema": {
			"type": "string"
		},
		"profiles": {
			"type": "object",
			"description": "Local adapter/model bindings.",
			"additionalProperties": {
				"$ref": "#/$defs/profile"
			}
		},
		"routines": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/routineEntry"
			}
		}
	},
	"$defs": {
		"profile": {
			"description": "A model binding: a built-in adapter shorthand/object, or a custom adapter in object form.",
			"oneOf": [
				{
					"type": "string",
					"pattern": "^claude(:(default|sonnet|opus|haiku|fable|claude-.*))?$",
					"description": "claude profile shorthand (e.g. \"claude\" or \"claude:<model>\")"
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["adapter"],
					"properties": {
						"adapter": {
							"const": "claude"
						},
						"model": {
							"type": "string",
							"anyOf": [
								{
									"enum": ["default", "sonnet", "opus", "haiku", "fable"]
								},
								{
									"pattern": "^claude-"
								}
							]
						},
						"effort": {
							"enum": ["low", "medium", "high", "max"]
						}
					}
				},
				{
					"type": "string",
					"pattern": "^codex(:(default|gpt-5\\.5|gpt-5\\.4-mini|gpt-.*|o\\d.*))?$",
					"description": "codex profile shorthand (e.g. \"codex\" or \"codex:<model>\")"
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["adapter"],
					"properties": {
						"adapter": {
							"const": "codex"
						},
						"model": {
							"type": "string",
							"anyOf": [
								{
									"enum": ["default", "gpt-5.5", "gpt-5.4-mini"]
								},
								{
									"pattern": "^gpt-"
								},
								{
									"pattern": "^o\\d"
								}
							]
						},
						"effort": {
							"enum": ["minimal", "low", "medium", "high", "xhigh"]
						}
					}
				},
				{
					"type": "string",
					"pattern": "^gemini(:(default|gemini-.*))?$",
					"description": "gemini profile shorthand (e.g. \"gemini\" or \"gemini:<model>\")"
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["adapter"],
					"properties": {
						"adapter": {
							"const": "gemini"
						},
						"model": {
							"type": "string",
							"anyOf": [
								{
									"enum": ["default"]
								},
								{
									"pattern": "^gemini-"
								}
							]
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["adapter"],
					"properties": {
						"adapter": {
							"type": "string",
							"minLength": 1,
							"not": {
								"enum": ["claude", "codex", "gemini"]
							}
						},
						"model": {
							"type": "string"
						},
						"effort": {
							"type": "string",
							"minLength": 1
						}
					}
				}
			]
		},
		"routineEntry": {
			"oneOf": [
				{
					"$ref": "#/$defs/fileRoutine"
				},
				{
					"$ref": "#/$defs/inlineRoutine"
				}
			]
		},
		"fileRoutine": {
			"type": "object",
			"additionalProperties": false,
			"required": ["file"],
			"properties": {
				"file": {
					"type": "string",
					"minLength": 1
				},
				"description": {
					"type": "string"
				},
				"defaults": {
					"$ref": "#/$defs/defaults"
				}
			}
		},
		"inlineRoutine": {
			"type": "object",
			"additionalProperties": false,
			"required": ["steps"],
			"properties": {
				"id": {
					"type": "string"
				},
				"description": {
					"type": "string"
				},
				"input": {
					"type": "string",
					"minLength": 1
				},
				"inputs": {
					"oneOf": [
						{
							"type": "array",
							"items": {
								"type": "string",
								"minLength": 1
							}
						},
						{
							"type": "object",
							"additionalProperties": {
								"$ref": "#/$defs/inputSpec"
							}
						}
					]
				},
				"agents": {
					"type": "object",
					"additionalProperties": {
						"$ref": "#/$defs/agent"
					}
				},
				"steps": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "#/$defs/step"
					}
				},
				"repeat": {
					"$ref": "#/$defs/repeat"
				},
				"output": {
					"type": "string"
				},
				"limits": {
					"$ref": "#/$defs/limits"
				},
				"changePolicy": {
					"$ref": "#/$defs/changePolicy"
				},
				"defaults": {
					"$ref": "#/$defs/defaults"
				}
			}
		},
		"inputSpec": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "string"
				},
				"required": {
					"type": "boolean"
				},
				"description": {
					"type": "string"
				}
			}
		},
		"agent": {
			"type": "object",
			"additionalProperties": false,
			"required": ["profile", "instructions", "filesystem"],
			"properties": {
				"profile": {
					"type": "string",
					"minLength": 1
				},
				"instructions": {
					"type": "string",
					"minLength": 1
				},
				"filesystem": {
					"enum": ["none", "read-only", "read-write"]
				}
			}
		},
		"step": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id"],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1
				},
				"call": {
					"type": "string",
					"minLength": 1
				},
				"prompt": {
					"type": "string",
					"minLength": 1
				},
				"format": {
					"type": "string",
					"minLength": 1
				},
				"check": {
					"$ref": "#/$defs/check"
				},
				"routine": {
					"type": "string",
					"minLength": 1
				},
				"inputs": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					}
				},
				"ask": {
					"type": "string",
					"minLength": 1
				},
				"json": {
					"$ref": "#/$defs/jsonOutput"
				}
			}
		},
		"check": {
			"oneOf": [
				{
					"type": "string",
					"minLength": 1
				},
				{
					"type": "array",
					"minItems": 1,
					"items": {
						"oneOf": [
							{
								"type": "string",
								"minLength": 1
							},
							{
								"$ref": "#/$defs/checkCommand"
							}
						]
					}
				}
			]
		},
		"checkCommand": {
			"type": "object",
			"additionalProperties": false,
			"required": ["command"],
			"properties": {
				"command": {
					"type": "string",
					"minLength": 1
				},
				"args": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"repeat": {
			"type": "object",
			"additionalProperties": false,
			"required": ["until"],
			"properties": {
				"until": {
					"$ref": "#/$defs/repeatUntil"
				},
				"maxIterations": {
					"type": "integer",
					"minimum": 1
				}
			}
		},
		"repeatUntil": {
			"oneOf": [
				{
					"const": "checks-pass"
				},
				{
					"$ref": "#/$defs/stepEquals"
				},
				{
					"$ref": "#/$defs/stepPathEquals"
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["all"],
					"properties": {
						"all": {
							"type": "array",
							"minItems": 1,
							"items": {
								"oneOf": [
									{
										"const": "checks-pass"
									},
									{
										"$ref": "#/$defs/stepEquals"
									},
									{
										"$ref": "#/$defs/stepPathEquals"
									}
								]
							}
						}
					}
				}
			]
		},
		"stepEquals": {
			"type": "object",
			"additionalProperties": false,
			"required": ["step", "equals"],
			"properties": {
				"step": {
					"type": "string",
					"minLength": 1
				},
				"equals": {
					"type": "string"
				}
			}
		},
		"jsonOutput": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema"],
			"properties": {
				"schema": {
					"type": "object",
					"description": "A JSON Schema subset (object/array/string/number/integer/boolean, with properties/required/additionalProperties/items/enum). The Chit parser enforces the supported subset and rejects unsupported keywords."
				}
			}
		},
		"stepPathEquals": {
			"type": "object",
			"additionalProperties": false,
			"required": ["step", "path", "equals"],
			"properties": {
				"step": {
					"type": "string",
					"minLength": 1
				},
				"path": {
					"type": "string",
					"minLength": 1
				},
				"equals": {
					"oneOf": [
						{
							"type": "string"
						},
						{
							"type": "number"
						},
						{
							"type": "boolean"
						}
					]
				}
			}
		},
		"limits": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"callTimeoutMinutes": {
					"$ref": "#/$defs/minutes"
				},
				"runTimeoutMinutes": {
					"$ref": "#/$defs/minutes"
				}
			}
		},
		"defaults": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"maxIterations": {
					"type": "integer",
					"minimum": 1
				}
			}
		},
		"changePolicy": {
			"type": "object",
			"additionalProperties": false,
			"minProperties": 1,
			"properties": {
				"allowedChangedPaths": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"deniedChangedPaths": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"minutes": {
			"oneOf": [
				{
					"type": "number",
					"exclusiveMinimum": 0
				},
				{
					"const": "none"
				}
			]
		}
	}
}
